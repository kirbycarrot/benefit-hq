# PostgreSQL connection used by Prisma and the application.
DATABASE_URL="postgresql://benefit_hq:replace-me@127.0.0.1:5432/benefit_hq"

# Generate independently with: openssl rand -base64 32
AUTH_SECRET="replace-with-a-random-auth-secret"

# Required only until the first administrator has been created. Use another
# independently generated secret, then remove it from the runtime environment.
BOOTSTRAP_TOKEN="replace-with-a-one-time-setup-token"

# Persistent private volume for generated decks and new client logos.
STORAGE_DIR="/var/lib/benefit-hq"
