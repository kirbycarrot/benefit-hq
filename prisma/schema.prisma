// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id           String   @id @default(cuid())
  email        String   @unique
  passwordHash String
  name         String
  isAdmin      Boolean  @default(false)
  createdAt    DateTime @default(now())

  clients               Client[]
  clientTeamAssignments ClientTeamAssignment[]
  uploadedDocuments     ClientDocument[]
}

model Client {
  id             String    @id @default(cuid())
  name           String
  logoPath       String?
  primaryColor   String    @default("#1F2937")
  secondaryColor String    @default("#14B8A6")
  createdById    String?
  createdBy      User?     @relation(fields: [createdById], references: [id], onDelete: SetNull)
  archivedAt     DateTime?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  planYears       PlanYear[]
  profile         ClientProfile?
  teamAssignments ClientTeamAssignment[]
  contacts        ClientContact[]
  locations       ClientLocation[]
  entities        ClientEntity[]
  priorities      ClientPriority[]
  documents       ClientDocument[]

  @@index([archivedAt])
}

model PlanYear {
  id            String   @id @default(cuid())
  clientId      String
  client        Client   @relation(fields: [clientId], references: [id], onDelete: Cascade)
  label         String
  effectiveDate DateTime
  createdAt     DateTime @default(now())

  policyLines      PolicyLine[]
  benefitPrograms  BenefitProgram[]
  censusUploads    CensusUpload[]
  employees        Employee[]
  deckConfig       DeckConfig?
  decks            Deck[]
  documents        ClientDocument[]
  benchmarkProfile PlanYearBenchmarkProfile?

  @@unique([clientId, label])
}

model ClientProfile {
  id        String @id @default(cuid())
  clientId  String @unique
  client    Client @relation(fields: [clientId], references: [id], onDelete: Cascade)
  legalName String

  website               String?
  primaryIndustry       String?
  secondaryIndustry     String?
  industryCode          String?
  ownershipType         String?
  parentCompany         String?
  privateEquitySponsor  String?
  fiscalYearEndMonth    Int?
  fiscalYearEndDay      Int?
  primaryRenewalMonth   Int?
  primaryRenewalDay     Int?
  usEmployeeCount       Int?
  globalEmployeeCount   Int?
  benefitsEligibleCount Int?
  enrolledEmployeeCount Int?

  entityStructure                  String?
  numberOfEins                     Int?
  benefitsConsistentAcrossEntities Boolean?
  hasUnionPopulation               Boolean?
  hasCollectivelyBargainedPlans    Boolean?
  hasAcquiredCompanies             Boolean?
  hasInternationalEmployees        Boolean?
  workforceTypes                   Json     @default("[]")
  coveredThroughPeo                Boolean?
  statesWithEmployees              Json     @default("[]")
  remoteEmployeePercentage         Decimal? @db.Decimal(5, 2)

  benefitChallenges         String?
  renewalSuccessOutcomes    String?
  budgetTarget              Decimal? @db.Decimal(14, 2)
  maximumAcceptableIncrease Decimal? @db.Decimal(5, 2)
  disruptionTolerance       String?
  excludedCarriers          Json     @default("[]")
  acquisitionsExpected      Boolean?
  headcountChangesExpected  Boolean?
  harmonizationUnderway     Boolean?
  preparingForTransaction   Boolean?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model ClientTeamAssignment {
  id       String @id @default(cuid())
  clientId String
  client   Client @relation(fields: [clientId], references: [id], onDelete: Cascade)
  userId   String
  user     User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  role     String

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([clientId, role])
  @@index([userId])
}

model ClientContact {
  id       String  @id @default(cuid())
  clientId String
  client   Client  @relation(fields: [clientId], references: [id], onDelete: Cascade)
  name     String
  title    String?
  email    String?
  phone    String?
  roles    Json    @default("[]")
  notes    String?

  sortOrder Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([clientId, sortOrder])
}

model ClientLocation {
  id             String  @id @default(cuid())
  clientId       String
  client         Client  @relation(fields: [clientId], references: [id], onDelete: Cascade)
  name           String
  line1          String
  line2          String?
  city           String
  state          String
  postalCode     String
  country        String  @default("United States")
  isHeadquarters Boolean @default(false)
  employeeCount  Int?

  sortOrder Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([clientId, sortOrder])
}

model ClientEntity {
  id            String  @id @default(cuid())
  clientId      String
  client        Client  @relation(fields: [clientId], references: [id], onDelete: Cascade)
  legalName     String
  taxIdLastFour String?
  notes         String?

  sortOrder Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([clientId, sortOrder])
}

model ClientPriority {
  id             String  @id @default(cuid())
  clientId       String
  client         Client  @relation(fields: [clientId], references: [id], onDelete: Cascade)
  objective      String
  rank           Int
  currentState   String?
  desiredOutcome String?
  measurementKpi String?
  notes          String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([clientId, objective])
  @@unique([clientId, rank])
}

model ClientDocument {
  id               String    @id @default(cuid())
  clientId         String
  client           Client    @relation(fields: [clientId], references: [id], onDelete: Cascade)
  planYearId       String?
  planYear         PlanYear? @relation(fields: [planYearId], references: [id], onDelete: Cascade)
  category         String
  originalFilename String
  filePath         String
  mediaType        String
  sizeBytes        Int
  uploadedById     String?
  uploadedBy       User?     @relation(fields: [uploadedById], references: [id], onDelete: SetNull)
  uploadedAt       DateTime  @default(now())

  @@index([clientId, category])
  @@index([planYearId])
  @@index([uploadedById])
}

model PolicyLine {
  id           String   @id @default(cuid())
  planYearId   String
  planYear     PlanYear @relation(fields: [planYearId], references: [id], onDelete: Cascade)
  coverageType String // Medical | Dental | Vision | Life | STD | LTD
  planName     String
  tier         String // EE | EE+Spouse | EE+Child | Family
  employeeCost Decimal  @db.Decimal(10, 2)
  employerCost Decimal  @db.Decimal(10, 2)
  totalPremium Decimal  @db.Decimal(10, 2)
  ratePeriod   String   @default("monthly")
  sortOrder    Int      @default(0)
  createdAt    DateTime @default(now())
}

model BenefitProgram {
  id          String   @id @default(cuid())
  planYearId  String
  planYear    PlanYear @relation(fields: [planYearId], references: [id], onDelete: Cascade)
  benefitType String // Medical | Dental | Vision | BasicLife | VoluntaryLife | STD | LTD
  offered     Boolean  @default(false)
  sortOrder   Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  plans BenefitPlan[]

  @@unique([planYearId, benefitType])
  @@index([planYearId, sortOrder])
}

model BenefitPlan {
  id                  String         @id @default(cuid())
  benefitProgramId    String
  benefitProgram      BenefitProgram @relation(fields: [benefitProgramId], references: [id], onDelete: Cascade)
  name                String
  subtype             String
  offered             Boolean        @default(true)
  details             Json           @default("{}")
  detailSchemaVersion Int            @default(1)
  renewedFromPlanId   String?
  renewedFromPlan     BenefitPlan?   @relation("BenefitPlanRenewal", fields: [renewedFromPlanId], references: [id], onDelete: SetNull)
  renewals            BenefitPlan[]  @relation("BenefitPlanRenewal")
  sortOrder           Int            @default(0)
  createdAt           DateTime       @default(now())
  updatedAt           DateTime       @updatedAt

  rates   PlanRate[]
  aliases PlanAlias[]

  @@index([benefitProgramId, sortOrder])
  @@index([renewedFromPlanId])
}

model PlanRate {
  id                   String      @id @default(cuid())
  benefitPlanId        String
  benefitPlan          BenefitPlan @relation(fields: [benefitPlanId], references: [id], onDelete: Cascade)
  tier                 String // EE | EE+Spouse | EE+Child | Family | EE+Dependent | EE+Family
  grossPremium         Decimal     @db.Decimal(10, 2)
  employeeContribution Decimal     @db.Decimal(10, 2)
  employerContribution Decimal     @db.Decimal(10, 2)
  ratePeriod           String      @default("monthly")
  enrollmentOverride   Int?
  sortOrder            Int         @default(0)
  createdAt            DateTime    @default(now())
  updatedAt            DateTime    @updatedAt

  @@unique([benefitPlanId, tier])
  @@index([benefitPlanId, sortOrder])
}

model PlanAlias {
  id              String      @id @default(cuid())
  benefitPlanId   String
  benefitPlan     BenefitPlan @relation(fields: [benefitPlanId], references: [id], onDelete: Cascade)
  alias           String
  normalizedAlias String
  createdAt       DateTime    @default(now())

  @@unique([benefitPlanId, normalizedAlias])
  @@index([normalizedAlias])
}

model CensusUpload {
  id         String   @id @default(cuid())
  planYearId String
  planYear   PlanYear @relation(fields: [planYearId], references: [id], onDelete: Cascade)
  filenames  Json // string[] of original filenames uploaded together
  status     String // processing | committed | failed
  warnings   Json // string[] of validation warnings surfaced to the user
  summary    Json? // headcount, dependent count, election count, etc.
  uploadedAt DateTime @default(now())
}

model Employee {
  id               String    @id @default(cuid())
  planYearId       String
  planYear         PlanYear  @relation(fields: [planYearId], references: [id], onDelete: Cascade)
  employeeNumber   String
  firstName        String
  lastName         String
  birthDate        DateTime?
  gender           String?
  hireDate         DateTime?
  employmentStatus String?
  baseSalary       Decimal?  @db.Decimal(12, 2)
  postalCode       String?

  dependents Dependent[]
  elections  BenefitElection[]

  @@unique([planYearId, employeeNumber])
}

model Dependent {
  id               String    @id @default(cuid())
  employeeId       String
  employee         Employee  @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  firstName        String?
  lastName         String?
  birthDate        DateTime?
  gender           String?
  relationshipType String? // Spouse | Child | ...
}

model BenefitElection {
  id          String   @id @default(cuid())
  employeeId  String
  employee    Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  benefitType String // Medical | Dental | Vision | Life | STD | LTD | VoluntaryLife | VoluntaryAD&D
  planName    String?
  optionName  String?
  volume      Decimal? @db.Decimal(12, 2) // for Life/STD/LTD elections
}

model ChartDefinition {
  id             String  @id @default(cuid())
  key            String  @unique
  label          String
  description    String
  category       String // Presentation section label
  defaultEnabled Boolean @default(true)
  sortOrder      Int     @default(0)
}

model DeckConfig {
  id         String   @id @default(cuid())
  planYearId String   @unique
  planYear   PlanYear @relation(fields: [planYearId], references: [id], onDelete: Cascade)
  selections Json // { [chartKey]: { enabled: boolean, params?: Record<string, unknown> } }
  updatedAt  DateTime @updatedAt
}

model Deck {
  id          String   @id @default(cuid())
  planYearId  String
  planYear    PlanYear @relation(fields: [planYearId], references: [id], onDelete: Cascade)
  filePath    String?
  status      String // generating | ready | failed
  generatedAt DateTime @default(now())
}

model BenchmarkDataset {
  id              String    @id @default(cuid())
  provider        String
  title           String
  surveyYear      Int
  publicationYear Int?
  version         String
  status          String    @default("draft") // draft | active | retired
  sourceFilename  String
  sourceChecksum  String
  receivedAt      DateTime?
  importedAt      DateTime  @default(now())
  notes           String?

  cohorts   BenchmarkCohort[]
  values    BenchmarkValue[]
  imports   BenchmarkImportRun[]
  planYears PlanYearBenchmarkProfile[]

  @@unique([provider, surveyYear, version])
  @@index([status, surveyYear])
}

model BenchmarkCohort {
  id               String           @id @default(cuid())
  datasetId        String
  dataset          BenchmarkDataset @relation(fields: [datasetId], references: [id], onDelete: Cascade)
  code             String
  type             String // national | region | size | industry
  label            String
  shortLabel       String
  sourceColumn     String
  participantCount Int?
  sortOrder        Int              @default(0)

  values               BenchmarkValue[]
  selectedForPlanYears PlanYearBenchmarkProfile[]

  @@unique([datasetId, code])
  @@index([datasetId, type, sortOrder])
}

model BenchmarkMetric {
  id             String  @id @default(cuid())
  code           String  @unique
  category       String
  label          String
  description    String?
  unit           String // percentage | currency_monthly | currency_annual | currency_pepy | count
  statistic      String // average | median | prevalence
  comparisonKind String  @default("direct") // direct | market_practice
  benefitType    String?
  planSubtype    String?
  tier           String?
  clientFieldKey String?
  direction      String  @default("neutral") // lower | higher | neutral
  sortOrder      Int     @default(0)

  values BenchmarkValue[]

  @@index([category, sortOrder])
  @@index([benefitType, planSubtype])
}

model BenchmarkValue {
  id           String           @id @default(cuid())
  datasetId    String
  dataset      BenchmarkDataset @relation(fields: [datasetId], references: [id], onDelete: Cascade)
  cohortId     String
  cohort       BenchmarkCohort  @relation(fields: [cohortId], references: [id], onDelete: Cascade)
  metricId     String
  metric       BenchmarkMetric  @relation(fields: [metricId], references: [id], onDelete: Cascade)
  numericValue Decimal?         @db.Decimal(18, 6)
  availability String           @default("available") // available | insufficient_data | not_reported | not_applicable
  sourceCell   String
  rawValue     String?

  @@unique([datasetId, cohortId, metricId])
  @@index([datasetId, metricId])
  @@index([cohortId, metricId])
}

model BenchmarkImportRun {
  id             String           @id @default(cuid())
  datasetId      String
  dataset        BenchmarkDataset @relation(fields: [datasetId], references: [id], onDelete: Cascade)
  status         String // running | succeeded | failed
  sourceChecksum String
  metricCount    Int              @default(0)
  cohortCount    Int              @default(0)
  valueCount     Int              @default(0)
  warningCount   Int              @default(0)
  warnings       Json             @default("[]")
  startedAt      DateTime         @default(now())
  completedAt    DateTime?

  @@index([datasetId, startedAt])
}

model PlanYearBenchmarkProfile {
  id              String           @id @default(cuid())
  planYearId      String           @unique
  planYear        PlanYear         @relation(fields: [planYearId], references: [id], onDelete: Cascade)
  datasetId       String
  dataset         BenchmarkDataset @relation(fields: [datasetId], references: [id], onDelete: Restrict)
  primaryCohortId String
  primaryCohort   BenchmarkCohort  @relation(fields: [primaryCohortId], references: [id], onDelete: Restrict)
  trendRate       Decimal?         @db.Decimal(7, 6)
  updatedAt       DateTime         @updatedAt
  createdAt       DateTime         @default(now())

  @@index([datasetId])
  @@index([primaryCohortId])
}
